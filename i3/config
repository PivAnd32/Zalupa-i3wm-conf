set $mod Mod4

font pango:monospace 8

exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork
exec --no-startup-id nm-applet
exec --no-startup-id setxkbmap -model pc105 -layout us -option grp:alt_shift_toggle #add layout if needs
exec_always /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
exec_always --no-startup-id ~/.config/polybar/launch.sh
exec_always --no-startup-id picom --config ~/.config/picom/picom.conf
exec --no-startup-id /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
exec_always --no-startup-id feh --bg-fill ~/wallpaper/linux.png
exec_always --no-startup-id gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'
exec_always --no-startup-id gsettings set org.gnome.desktop.interface gtk-theme 'Adwaita-dark'
exec_always --no-startup-id xset s off
exec_always --no-startup-id xset -dpms
floating_modifier $mod
tiling_drag modifier titlebar

set $refresh_i3status killall -SIGUSR1 i3status

bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +2% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -2% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

bindsym $mod+Return exec alacritty
bindsym $mod+q kill
bindsym $mod+d exec --no-startup-id j4-dmenu-desktop --dmenu 'dmenu -l 12 -fn "Fira Code:size=12" -nb "#282A2E" -nf "#C5C8C6" -sb "#373B41" -sf "#F0C674"'
bindsym $mod+f fullscreen toggle
bindsym $mod+s floating toggle
bindsym $mod+a focus parent
bindsym $mod+e exec nemo
bindsym $mod+z exec zeditor
bindsym $mod+c exec discord
bindsym $mod+w exec firefox

client.focused          #F0C674 #F0C674 #F0C674 #F0C674
client.unfocused        #373B41 #282A2E #707880
client.focused_inactive #707880 #282A2E #C5C8C6
client.urgent           #A54242 #A54242 #C5C8C6
client.background       #282A2E

default_border pixel 2
default_floating_border pixel 2
gaps inner 10
gaps outer 5
smart_gaps on

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym --whole-window $mod+button4 workspace next
bindsym --whole-window $mod+button5 workspace prev

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

bindsym $mod+Shift+r restart
